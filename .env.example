# TripPlanner local environment — copy to .env (which is gitignored) and fill in real values.
# Every value here is a placeholder; replacing or removing one has no effect on security.

# --- Backend ---

# Neon Postgres connection string (or any Postgres URL). The backend accepts both
# the raw `postgresql://...` form that Neon hands out and the JDBC-prefixed
# `jdbc:postgresql://...` form.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# 32 random bytes (hex), used to sign HS256 JWTs. Generate with:
#   openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_32_RANDOM_BYTES_HEX

# 16 random bytes (hex), used to hash emails before they hit log aggregators. Generate with:
#   openssl rand -hex 16
LOG_EMAIL_PEPPER=REPLACE_WITH_16_RANDOM_BYTES_HEX

# CORS allowlist — exact origin of the frontend. Comma-separated for multiple.
APP_FRONTEND_ORIGIN=http://localhost:3000

# Local-only dev password reset helper. Use the same value for the Vite var below.
APP_DEV_PASSWORD_RESET_SECRET=REPLACE_WITH_LOCAL_DEV_RESET_SECRET

# Backend-only Google Maps key for server-side Places, Geocoding, Routes, and
# photo media requests. Do not expose this value to the frontend.
GOOGLE_MAPS_SERVER_API_KEY=REPLACE_WITH_GOOGLE_MAPS_SERVER_KEY

# Optional, but strongly recommended before running OWASP Dependency-Check locally
# or in CI. Request one at https://nvd.nist.gov/developers/request-an-api-key.
NVD_API_KEY=REPLACE_WITH_NVD_API_KEY

# --- Frontend (Vite exposes only VITE_ prefixed vars to the browser) ---

# Google Maps browser API key for Maps JavaScript rendering only.
# Restrict HTTP referrers to localhost + prod origins.
VITE_GOOGLE_MAPS_BROWSER_KEY=REPLACE_WITH_GOOGLE_MAPS_BROWSER_KEY

# Optional Google Maps vector map id for cloud styling. Not required locally.
VITE_GOOGLE_MAPS_MAP_ID=

# Lets the dev login page call the local-only reset helper.
VITE_DEV_PASSWORD_RESET_SECRET=REPLACE_WITH_LOCAL_DEV_RESET_SECRET
