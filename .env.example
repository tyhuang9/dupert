# TripPlanner local environment — copy to .env (which is gitignored) and fill in real values.
# Every value here is a placeholder; replacing or removing one has no effect on security.

# --- Backend ---

# Neon Postgres connection string (or any Postgres URL). The backend accepts both
# the raw `postgresql://...` form that Neon hands out and the JDBC-prefixed
# `jdbc:postgresql://...` form.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# 32 random bytes (hex), used to sign HS256 JWTs. Generate with:
#   openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_32_RANDOM_BYTES_HEX

# 16 random bytes (hex), used to hash emails before they hit log aggregators. Generate with:
#   openssl rand -hex 16
LOG_EMAIL_PEPPER=REPLACE_WITH_16_RANDOM_BYTES_HEX

# CORS allowlist — exact origin of the frontend. Comma-separated for multiple.
APP_FRONTEND_ORIGIN=http://localhost:3000

# --- Frontend (Vite exposes only VITE_ prefixed vars to the browser) ---

# Mapbox public token. URL-restrict in the Mapbox dashboard to localhost + prod origins.
VITE_MAPBOX_TOKEN=pk.REPLACE_WITH_MAPBOX_PUBLIC_TOKEN

# Backend base URL the SPA talks to.
VITE_API_BASE_URL=http://localhost:8000
