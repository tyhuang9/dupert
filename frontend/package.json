{
  "name": "dupert",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode web-development",
    "dev:web:staging": "vite --mode web-staging",
    "dev:web:production": "vite --mode web-production",
    "build": "tsc -b && vite build --mode web-production",
    "build:web:development": "tsc -b && vite build --mode web-development",
    "build:web:staging": "tsc -b && vite build --mode web-staging",
    "build:web:production": "tsc -b && vite build --mode web-production",
    "build:native:development": "tsc -b && vite build --mode native-development && node scripts/check-native-bundle-policy.mjs",
    "build:native:staging": "tsc -b && vite build --mode native-staging && node scripts/check-native-bundle-policy.mjs",
    "build:native:production": "tsc -b && vite build --mode native-production && node scripts/check-native-bundle-policy.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run && node --test scripts/check-native-bundle-policy.node-test.mjs",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "check:native-bundle-policy": "node scripts/check-native-bundle-policy.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@tanstack/react-query": "^5.100.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vis.gl/react-google-maps": "^1.8.3",
    "axios": "^1.15.2",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/google.maps": "^3.65.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "axios-mock-adapter": "^2.1.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "puppeteer": "^25.2.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "allowScripts": {
    "fsevents@2.3.3": true,
    "fsevents@2.3.2": true,
    "puppeteer@25.2.1": true
  }
}
