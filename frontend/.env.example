# TripPlanner frontend environment - copy to frontend/.env and fill in real values.
# Vite exposes only VITE_ prefixed variables to the browser bundle.

# Google Maps browser API key for Maps JavaScript rendering.
# Restrict HTTP referrers to localhost + production origins.
VITE_GOOGLE_MAPS_API_KEY=REPLACE_WITH_GOOGLE_MAPS_BROWSER_KEY

# Backend base URL. Leave empty for local Vite proxying/same-origin /api.
# For split deployments, set only the backend origin, e.g. https://backend.example.com.
VITE_BACKEND_API_URL=

# Optional lightweight app wall password. This is bundled into the browser and is
# only a soft gate, not real access control.
VITE_APP_ACCESS_PASSWORD=REPLACE_WITH_SHARED_APP_PASSWORD

# Optional Google Maps vector map id for cloud styling. Not required locally.
VITE_GOOGLE_MAPS_MAP_ID=
