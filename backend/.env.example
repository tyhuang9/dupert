# Dupert backend environment - copy to backend/.env and fill in real values.
# The local DATABASE_URL below is ready to use; replace the explicit placeholders
# in the remaining settings with development values.

# Local PostgreSQL is the recommended development default. Start it with
# `npm run db:up`; these intentionally weak credentials are safe only on your
# machine because Compose binds Postgres to 127.0.0.1. The backend accepts both
# raw `postgresql://...` and JDBC-prefixed `jdbc:postgresql://...` URLs.
# To keep using a Neon database, replace this value with its connection string.
DATABASE_URL=postgresql://dupert:dupert_local_dev_password@127.0.0.1:5432/dupert

# Hikari connection budget for one Render instance. Use Neon's direct endpoint
# here; do not layer Neon's pooled endpoint over this application pool unless
# deployment grows to multiple backend instances and telemetry shows pressure.
DB_POOL_MAX_SIZE=4
DB_POOL_MIN_IDLE=0
DB_CONNECTION_TIMEOUT_MS=10000
DB_VALIDATION_TIMEOUT_MS=3000

# Local backend profile. Render should set SPRING_PROFILES_ACTIVE=prod.
SPRING_PROFILES_ACTIVE=local

# 32 random bytes (hex), used to sign HS256 JWTs. Generate with:
#   openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_32_RANDOM_BYTES_HEX

# 16 random bytes (hex), used to hash emails before they hit log aggregators. Generate with:
#   openssl rand -hex 16
LOG_EMAIL_PEPPER=REPLACE_WITH_16_RANDOM_BYTES_HEX

# Browser CORS allowlist - exact frontend origins only. Comma-separated for multiple.
ALLOWED_ORIGINS=http://localhost:3000

# Native WebView CORS allowlist. Keep exact standard Capacitor origins; never use
# a wildcard. Set these deployed values on both Render backends, then confirm the
# observed Origin header from a packaged app before release.
NATIVE_ALLOWED_ORIGINS=capacitor://localhost,https://localhost

# Public frontend URL used in password reset and email verification links.
APP_PUBLIC_FRONTEND_URL=http://localhost:3000

# Trust X-Forwarded-For only behind a platform proxy that overwrites it. Render should set true.
APP_TRUST_PROXY=false

# Realtime SSE lifecycle. Heartbeats detect dead WebViews promptly; stale-after
# must allow at least two heartbeat intervals, and max-lifetime must be greater
# than stale-after so healthy clients periodically renew their transport.
SSE_HEARTBEAT_INTERVAL=15s
SSE_STALE_AFTER=30s
SSE_MAX_LIFETIME=2m

# Production transport hardening. Local development should leave these false so HTTP works.
# Render should set these explicit true values along with SPRING_PROFILES_ACTIVE=prod.
APP_COOKIES_SECURE=false
APP_COOKIES_SAME_SITE=Strict
SECURE_HSTS_ENABLED=false

# Open signup. In prod, keep true only when Brevo is configured.
SIGNUP_ENABLED=true

# Render production starter set:
# SPRING_PROFILES_ACTIVE=prod
# APP_TRUST_PROXY=true
# ALLOWED_ORIGINS=https://dupert.vercel.app
# NATIVE_ALLOWED_ORIGINS=capacitor://localhost,https://localhost
# APP_COOKIES_SECURE=true
# APP_COOKIES_SAME_SITE=None
# SECURE_HSTS_ENABLED=true
# APP_PUBLIC_FRONTEND_URL=https://dupert.vercel.app
# SIGNUP_ENABLED=false
# If SIGNUP_ENABLED=true in prod, also set BREVO_API_KEY, APP_EMAIL_FROM_EMAIL,
# and APP_EMAIL_FROM_NAME to a verified Brevo transactional sender.

# Brevo transactional email. Local and test profiles use a no-op sender.
BREVO_API_KEY=REPLACE_WITH_BREVO_API_KEY
APP_EMAIL_FROM_EMAIL=no-reply@example.com
APP_EMAIL_FROM_NAME=Dupert

# Backend-local Google Maps key for Places, Geocoding, Routes, and photo media requests.
# Do not expose this value to the frontend.
GOOGLE_MAPS_API_KEY=REPLACE_WITH_GOOGLE_MAPS_KEY

# Optional, but strongly recommended before running OWASP Dependency-Check locally
# or in CI. Request one at https://nvd.nist.gov/developers/request-an-api-key.
NVD_API_KEY=REPLACE_WITH_NVD_API_KEY
