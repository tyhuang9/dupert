# TripPlanner backend environment - copy to backend/.env and fill in real values.
# Every value here is a placeholder; replacing or removing one has no effect on security.

# Neon Postgres connection string (or any Postgres URL). The backend accepts both
# the raw `postgresql://...` form that Neon hands out and the JDBC-prefixed
# `jdbc:postgresql://...` form.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# 32 random bytes (hex), used to sign HS256 JWTs. Generate with:
#   openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_32_RANDOM_BYTES_HEX

# 16 random bytes (hex), used to hash emails before they hit log aggregators. Generate with:
#   openssl rand -hex 16
LOG_EMAIL_PEPPER=REPLACE_WITH_16_RANDOM_BYTES_HEX

# CORS allowlist - exact origin of the frontend. Comma-separated for multiple.
ALLOWED_ORIGINS=http://localhost:3000

# Local-only dev password reset helper. Use the same value for the Vite var in frontend/.env.
APP_DEV_PASSWORD_RESET_SECRET=REPLACE_WITH_LOCAL_DEV_RESET_SECRET

# Backend-local Google Maps key for Places, Geocoding, Routes, and photo media requests.
# Do not expose this value to the frontend.
GOOGLE_MAPS_API_KEY=REPLACE_WITH_GOOGLE_MAPS_KEY

# Optional, but strongly recommended before running OWASP Dependency-Check locally
# or in CI. Request one at https://nvd.nist.gov/developers/request-an-api-key.
NVD_API_KEY=REPLACE_WITH_NVD_API_KEY
